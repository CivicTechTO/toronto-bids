# Toronto Bids scraper — local credentials.
#
# Copy this file to `scrapers/.env` and fill in real values:
#     cp scrapers/.env.example scrapers/.env
#
# `scrapers/.env` is gitignored (never committed). These are read only by the
# P4b authenticated Ariba attachment fetcher; every other source is public and
# needs no credentials. Leave blank to keep the attachment fetcher disabled.

# Toronto-realm SAP Ariba supplier login (passwordadapter=SourcingSupplierUser, realm=toronto).
ARIBA_USERNAME=
ARIBA_PASSWORD=
